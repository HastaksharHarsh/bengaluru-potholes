{
  "name": "bengaluru-road-watch-backend",
  "version": "1.0.0",
  "description": "Backend API for Bengaluru Road Watch pothole intelligence platform",
  "main": "dist/index.js",
  "scripts": {
    "dev:node": "tsx watch src/index.ts",
    "dev:python": "cd model && python server.py",
    "dev": "concurrently \"npm run dev:node\" \"npm run dev:python\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.15.0",
    "@google-cloud/vertexai": "^1.9.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "firebase-admin": "^13.4.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "ngeohash": "^0.6.3",
    "sharp": "^0.33.5",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.16.5",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}